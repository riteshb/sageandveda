{%- comment -%}
  Persistent Tab + Slide-In Panel
  ─────────────────────────────────────────────────────────────
  Fixed vertical tab on left edge. Appears 30s after page load.
  Two modes based on cookies:
    Mode 1 — Email capture (popup dismissed, not subscribed)
    Mode 2 — GWP reminder (Klaviyo __kla_id cookie present)
  Suppressed if neither cookie exists.
  Not rendered on /cart or /checkout (handled in theme.liquid).
{%- endcomment -%}

<div id="sv-ptab" class="sv-ptab" aria-hidden="true">

  <!-- Overlay — darkens page when panel is open -->
  <div class="sv-ptab__overlay" id="sv-ptab-overlay" aria-hidden="true"></div>

  <!-- Vertical tab trigger -->
  <button class="sv-ptab__tab" id="sv-ptab-trigger" type="button"
          aria-expanded="false" aria-controls="sv-ptab-panel"
          aria-label="Open special offer">
    <span class="sv-ptab__label" id="sv-ptab-label">GET 10% OFF</span>
  </button>

  <!-- Slide-in panel -->
  <aside class="sv-ptab__panel" id="sv-ptab-panel" role="dialog"
         aria-modal="true" aria-label="Special offer" aria-hidden="true">

    <button class="sv-ptab__close" id="sv-ptab-close" type="button" aria-label="Close panel">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M18 6 6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>

    <p class="sv-ptab__brand">sage & veda</p>

    <!-- ── MODE 1: Email Capture ── -->
    <div class="sv-ptab__mode" id="sv-ptab-mode1" aria-hidden="true">
      <h2 class="sv-ptab__headline">Still thinking about it?</h2>
      <p class="sv-ptab__sub">Leave your email and we'll send 10% off your first order.</p>

      <form class="sv-ptab__form" id="sv-ptab-form" novalidate>
        <input type="email"
               class="sv-ptab__input"
               id="sv-ptab-email"
               placeholder="your@email.com"
               autocomplete="email"
               aria-label="Email address"
               required>
        <button type="submit" class="sv-ptab__submit">CLAIM 10% OFF</button>
        <p class="sv-ptab__legal">By joining you agree to receive marketing emails. Unsubscribe anytime.</p>
      </form>

      <div class="sv-ptab__success" id="sv-ptab-success" aria-hidden="true">
        <p class="sv-ptab__success-hl">You're in.</p>
        <p class="sv-ptab__success-sub">Check your inbox for your 10% off code.</p>
      </div>
    </div>

    <!-- ── MODE 2: GWP Reminder ── -->
    <div class="sv-ptab__mode" id="sv-ptab-mode2" aria-hidden="true">
      <p class="sv-ptab__eyebrow">FREE WITH YOUR ORDER</p>
      <h2 class="sv-ptab__headline">Spend $65. Get a mystery gift.</h2>
      <div class="sv-ptab__gwp-img-wrap">
        <img src="{{ 'sv-placeholder-hero.jpg' | asset_url }}"
             alt="Free gift with purchase"
             class="sv-ptab__gwp-img"
             loading="lazy">
      </div>
      <p class="sv-ptab__sub">Automatically added at checkout when your order hits $65. No code needed.</p>
      <a href="/collections/all" class="sv-ptab__gwp-btn">SHOP THE COLLECTION</a>
    </div>

  </aside>
</div>

<style>
/* ══ PERSISTENT TAB — hidden until JS determines mode ══ */
.sv-ptab { display: none; }
.sv-ptab.is-ready { display: block; }

/* ── Overlay ── */
.sv-ptab__overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.45);
  z-index: 1199;
  opacity: 0;
  pointer-events: none;
  transition: opacity 300ms ease;
}
.sv-ptab.panel-open .sv-ptab__overlay {
  opacity: 1;
  pointer-events: all;
}

/* ── Vertical tab ── */
.sv-ptab__tab {
  position: fixed;
  left: 0;
  top: 50%;
  transform: translateY(-50%) translateX(-100%);
  z-index: 1200;
  width: 32px;
  height: 120px;
  border: none;
  border-radius: 0 8px 8px 0;
  background: #002816;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  box-shadow: 2px 0 12px rgba(0,0,0,0.18);
  transition: transform 400ms cubic-bezier(0.32,0.72,0,1),
              width 200ms ease;
}
.sv-ptab__tab:hover { width: 36px; }
.sv-ptab.is-visible .sv-ptab__tab { transform: translateY(-50%) translateX(0); }
.sv-ptab.mode-2 .sv-ptab__tab { background: #b6522d; }

.sv-ptab__label {
  writing-mode: vertical-rl;
  transform: rotate(180deg);
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #FDFAF4;
  white-space: nowrap;
  user-select: none;
  pointer-events: none;
}

/* ── Panel ── */
.sv-ptab__panel {
  position: fixed;
  top: 0;
  left: 0;
  width: 320px;
  max-width: 100vw;
  height: 100%;
  background: #FDFAF4;
  z-index: 1200;
  transform: translateX(-100%);
  transition: transform 360ms cubic-bezier(0.32,0.72,0,1);
  display: flex;
  flex-direction: column;
  padding: 56px 40px 40px;
  box-shadow: 4px 0 32px rgba(0,0,0,0.14);
  overflow-y: auto;
  box-sizing: border-box;
}
.sv-ptab.panel-open .sv-ptab__panel { transform: translateX(0); }

@media (max-width: 480px) {
  .sv-ptab__panel { width: 100vw; padding: 56px 32px 32px; }
}

/* ── Close button ── */
.sv-ptab__close {
  position: absolute;
  top: 12px;
  right: 12px;
  background: none;
  border: none;
  cursor: pointer;
  color: #002816;
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 150ms;
}
.sv-ptab__close:hover { opacity: 0.6; }

/* ── Brand mark ── */
.sv-ptab__brand {
  font-family: 'Rozha One', serif;
  font-size: 16px;
  color: #002816;
  text-align: center;
  margin: 0 0 28px;
}

/* ── Mode containers ── */
.sv-ptab__mode { display: none; text-align: center; }
.sv-ptab__mode.is-active { display: block; }

/* ── Typography ── */
.sv-ptab__eyebrow {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #b6522d;
  margin: 0 0 10px;
}
.sv-ptab__headline {
  font-family: 'Cormorant Garamond', serif;
  font-size: 32px;
  font-weight: 400;
  color: #002816;
  line-height: 1.15;
  margin: 0 0 12px;
}
.sv-ptab__sub {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 14px;
  color: #4A7B5E;
  line-height: 1.7;
  margin: 0 0 24px;
}

/* ── Mode 1: Form ── */
.sv-ptab__input {
  width: 100%;
  height: 48px;
  border: 1px solid #B29D94;
  border-radius: 4px;
  padding: 0 16px;
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 14px;
  color: #002816;
  background: #fff;
  box-sizing: border-box;
  display: block;
  margin-bottom: 12px;
  transition: border-color 150ms;
}
.sv-ptab__input:focus { outline: none; border-color: #002816; }
.sv-ptab__input.is-error { border-color: #C0392B; }

.sv-ptab__submit {
  width: 100%;
  height: 52px;
  background: #002816;
  color: #FDFAF4;
  border: none;
  border-radius: 4px;
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  cursor: pointer;
  margin-bottom: 12px;
  transition: opacity 150ms;
}
.sv-ptab__submit:hover { opacity: 0.85; }
.sv-ptab__submit:disabled { opacity: 0.6; cursor: not-allowed; }

.sv-ptab__legal {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 11px;
  color: #B29D94;
  line-height: 1.6;
  margin: 0;
}

/* ── Mode 1: Success ── */
.sv-ptab__success { text-align: center; padding: 24px 0; }
.sv-ptab__success-hl {
  font-family: 'Cormorant Garamond', serif;
  font-size: 32px;
  font-style: italic;
  color: #002816;
  margin: 0 0 8px;
}
.sv-ptab__success-sub {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 14px;
  color: #4A7B5E;
  margin: 0;
}

/* ── Mode 2: GWP ── */
.sv-ptab__gwp-img-wrap {
  width: 100%;
  max-height: 180px;
  overflow: hidden;
  border-radius: 8px;
  margin-bottom: 16px;
  background: #F0EDE6;
}
.sv-ptab__gwp-img {
  width: 100%;
  height: 180px;
  object-fit: contain;
  display: block;
}
.sv-ptab__gwp-btn {
  display: block;
  width: 100%;
  height: 52px;
  line-height: 52px;
  background: #FFD786;
  color: #002816;
  border-radius: 4px;
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  text-align: center;
  text-decoration: none;
  margin-top: 16px;
  transition: opacity 150ms;
}
.sv-ptab__gwp-btn:hover { opacity: 0.85; }
</style>

<script>
(function () {
  'use strict';

  var SHOW_DELAY   = 30000; // 30 seconds
  var SESSION_KEY  = 'sv_ptab_closed';

  function getCookie(name) {
    try {
      var m = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
      return m ? m[2] : null;
    } catch(e) { return null; }
  }

  function setSessionClosed() {
    try { sessionStorage.setItem(SESSION_KEY, '1'); } catch(e) {}
  }

  function wasClosedThisSession() {
    try { return !!sessionStorage.getItem(SESSION_KEY); } catch(e) { return false; }
  }

  /* ── Elements ── */
  var ptab     = document.getElementById('sv-ptab');
  var trigger  = document.getElementById('sv-ptab-trigger');
  var panel    = document.getElementById('sv-ptab-panel');
  var overlay  = document.getElementById('sv-ptab-overlay');
  var closeBtn = document.getElementById('sv-ptab-close');
  var label    = document.getElementById('sv-ptab-label');
  var mode1El  = document.getElementById('sv-ptab-mode1');
  var mode2El  = document.getElementById('sv-ptab-mode2');
  var form     = document.getElementById('sv-ptab-form');
  var emailEl  = document.getElementById('sv-ptab-email');
  var successEl = document.getElementById('sv-ptab-success');

  if (!ptab || !trigger || !panel) return;

  /* ── Determine mode ── */
  var isSubscribed    = !!getCookie('__kla_id');
  var popupDismissed  = !!getCookie('sv_popup_dismissed');

  var mode = null;
  if (isSubscribed) {
    mode = 2;
  } else if (popupDismissed) {
    mode = 1;
  }

  /* No mode → do not render tab */
  if (!mode) return;

  /* Apply mode */
  ptab.classList.add('mode-' + mode);
  if (mode === 1) {
    label.textContent = 'GET 10% OFF';
    if (mode1El) { mode1El.classList.add('is-active'); mode1El.removeAttribute('aria-hidden'); }
  } else {
    label.textContent = 'FREE GIFT';
    if (mode2El) { mode2El.classList.add('is-active'); mode2El.removeAttribute('aria-hidden'); }
  }

  ptab.classList.add('is-ready');

  /* ── Open / Close ── */
  function openPanel() {
    ptab.classList.add('panel-open');
    trigger.setAttribute('aria-expanded', 'true');
    panel.removeAttribute('aria-hidden');
    ptab.removeAttribute('aria-hidden');
    document.body.style.overflow = 'hidden';
    setTimeout(function() { if (closeBtn) closeBtn.focus(); }, 360);
  }

  function closePanel() {
    ptab.classList.remove('panel-open');
    trigger.setAttribute('aria-expanded', 'false');
    panel.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    setSessionClosed();
    setTimeout(function() { trigger.focus(); }, 50);
  }

  trigger.addEventListener('click', function() {
    ptab.classList.contains('panel-open') ? closePanel() : openPanel();
  });

  if (closeBtn)  closeBtn.addEventListener('click', closePanel);
  if (overlay)   overlay.addEventListener('click', closePanel);

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && ptab.classList.contains('panel-open')) closePanel();
  });

  /* ── Mode 1: Form submission ── */
  if (form && mode === 1) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var email = emailEl ? emailEl.value.trim() : '';
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        if (emailEl) emailEl.classList.add('is-error');
        return;
      }
      if (emailEl) emailEl.classList.remove('is-error');

      /* Hide form, show success */
      form.style.display = 'none';
      if (successEl) {
        successEl.style.display = 'block';
        successEl.removeAttribute('aria-hidden');
      }

      /* Auto-close after 4 seconds */
      setTimeout(closePanel, 4000);
    });

    if (emailEl) {
      emailEl.addEventListener('input', function() { emailEl.classList.remove('is-error'); });
    }
  }

  /* ── Show tab after delay (skip delay if previously closed this session) ── */
  if (wasClosedThisSession()) {
    ptab.classList.add('is-visible');
  } else {
    setTimeout(function() {
      ptab.classList.add('is-visible');
    }, SHOW_DELAY);
  }

})();
</script>
