<style>
  /* ── Reset / Base ──────────────────────────────────────── */
  .sv-mood * { box-sizing: border-box; margin: 0; padding: 0; }
  .sv-mood img { display: block; width: 100%; }
  .sv-mood a { text-decoration: none; color: inherit; }

  /* ── Section 1: Hero Banner ────────────────────────────── */
  .sv-mood-hero {
    position: relative;
    width: 100%;
    height: 70vh;
    min-height: 480px;
    overflow: hidden;
  }
  .sv-mood-hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .sv-mood-hero__overlay {
    position: absolute;
    inset: 0;
  }
  .sv-mood-hero__content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 24px;
    text-align: center;
  }
  .sv-mood-hero__number {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 12px;
    color: rgba(253, 250, 244, 0.5);
    letter-spacing: 0.15em;
    margin-bottom: 12px;
    text-transform: uppercase;
  }
  .sv-mood-hero__name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 64px;
    color: #FDFAF4;
    line-height: 1;
    margin-bottom: 20px;
  }
  .sv-mood-hero__descriptor {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 16px;
    color: rgba(253, 250, 244, 0.85);
    max-width: 560px;
    line-height: 1.5;
  }

  /* ── Section 2: Editorial Spacer ───────────────────────── */
  .sv-mood-spacer {
    background: #FDFAF4;
    padding: 64px 24px;
    text-align: center;
  }
  .sv-mood-spacer__inner {
    max-width: 720px;
    margin: 0 auto;
  }
  .sv-mood-spacer__statement {
    font-family: 'Cormorant Garamond', serif;
    font-size: 34px;
    color: #002816;
    line-height: 1.15;
  }

  /* ── Section 3: Mood Introduction ──────────────────────── */
  .sv-mood-intro {
    background: #FDFAF4;
    padding: 80px 24px;
  }
  .sv-mood-intro__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column-reverse;
    gap: 40px;
  }
  .sv-mood-intro__text {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .sv-mood-intro__eyebrow {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 16px;
  }
  .sv-mood-intro__headline {
    font-family: 'Cormorant Garamond', serif;
    font-size: 30px;
    color: #002816;
    line-height: 1.2;
    margin-bottom: 20px;
  }
  .sv-mood-intro__body {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 16px;
    color: #4A7B5E;
    line-height: 1.8;
    max-width: 480px;
  }
  .sv-mood-intro__image-wrap {
    width: 100%;
    aspect-ratio: 3 / 4;
    border-radius: 12px;
    overflow: hidden;
  }
  .sv-mood-intro__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ── Section 4A: Hero Product ───────────────────────────── */
  .sv-mood-hero-product {
    background: #FDFAF4;
    padding: 80px 0 40px;
  }
  .sv-mood-hero-product__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
  }
  .sv-mood-hero-product__image-wrap {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }
  .sv-mood-hero-product__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .sv-mood-hero-product__content {
    padding: 32px 24px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .sv-mood-product__eyebrow {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 8px;
  }
  .sv-mood-product__name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 42px;
    color: #002816;
    line-height: 1.1;
  }
  .sv-mood-product__tagline {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 20px;
    color: #4A7B5E;
    margin-top: 8px;
  }
  .sv-mood-product__bullets {
    list-style: none;
    margin-top: 20px;
  }
  .sv-mood-product__bullets li {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 14px;
    color: #4A7B5E;
    line-height: 1.7;
    padding-left: 18px;
    position: relative;
    margin-bottom: 4px;
  }
  .sv-mood-product__bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 8px;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: var(--mood-color, #002816);
  }
  .sv-mood-product__size-label {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #002816;
    margin-top: 24px;
    margin-bottom: 10px;
  }
  .sv-mood-product__sizes {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .sv-mood-size-pill {
    height: 44px;
    padding: 0 24px;
    border-radius: 999px;
    border: 1.5px solid #002816;
    background: #fff;
    color: #002816;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    line-height: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2px;
  }
  .sv-mood-size-pill span.pill-price {
    font-size: 11px;
    opacity: 0.7;
  }
  .sv-mood-size-pill.active {
    background-color: var(--mood-color, #002816);
    border-color: var(--mood-color, #002816);
    color: #FDFAF4;
  }
  .sv-mood-product__price-display {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 16px;
    font-weight: 600;
    color: #002816;
    margin-top: 12px;
  }
  .sv-mood-product__atc {
    display: block;
    width: 100%;
    height: 52px;
    background: #FFD786;
    color: #002816;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    margin-top: 16px;
    transition: opacity 0.2s;
  }
  .sv-mood-product__atc:hover { opacity: 0.88; }
  .sv-mood-product__pdp-link {
    display: block;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 13px;
    color: #4A7B5E;
    text-align: center;
    margin-top: 12px;
  }
  .sv-mood-product__pdp-link:hover { text-decoration: underline; }

  /* ── Section 4B: Also In This Mood ─────────────────────── */
  .sv-mood-also {
    background: #FDFAF4;
    padding: 0 24px 80px;
  }
  .sv-mood-also__inner {
    max-width: 1200px;
    margin: 0 auto;
  }
  .sv-mood-also__header {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 24px;
  }
  .sv-mood-also__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .sv-mood-also-card {
    display: block;
    cursor: pointer;
  }
  .sv-mood-also-card__img-wrap {
    width: 100%;
    aspect-ratio: 3 / 4;
    border-radius: 8px;
    overflow: hidden;
  }
  .sv-mood-also-card__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .sv-mood-also-card:hover .sv-mood-also-card__img-wrap img {
    transform: scale(1.03);
  }
  .sv-mood-also-card__name {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 15px;
    font-weight: 600;
    color: #002816;
    margin-top: 12px;
  }
  .sv-mood-also-card__tagline {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 13px;
    color: #4A7B5E;
    margin-top: 4px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .sv-mood-also-card__price {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 14px;
    color: #002816;
    margin-top: 6px;
  }
  .sv-mood-also-card__btn {
    display: block;
    width: 100%;
    margin-top: 12px;
    padding: 10px 0;
    border: 1.5px solid #002816;
    border-radius: 4px;
    text-align: center;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 13px;
    color: #002816;
    background: transparent;
    transition: background 0.2s, color 0.2s;
    cursor: pointer;
  }
  .sv-mood-also-card:hover .sv-mood-also-card__btn {
    background: #002816;
    color: #FDFAF4;
  }

  /* ── Section 5: Mood Cues ───────────────────────────────── */
  .sv-mood-cues {
    background: #002816;
    padding: 56px 24px;
  }
  .sv-mood-cues__inner {
    max-width: 1200px;
    margin: 0 auto;
  }
  .sv-mood-cues__header {
    text-align: center;
    margin-bottom: 48px;
  }
  .sv-mood-cues__eyebrow {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #FFD786;
    margin-bottom: 12px;
  }
  .sv-mood-cues__headline {
    font-family: 'Cormorant Garamond', serif;
    font-size: 30px;
    color: #FDFAF4;
    line-height: 1.2;
  }
  .sv-mood-cues__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }
  .sv-mood-cue-card {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 12px;
    padding: 32px;
  }
  .sv-mood-cue-card__number {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 11px;
    color: rgba(253, 250, 244, 0.4);
  }
  .sv-mood-cue-card__name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 28px;
    color: #FDFAF4;
    margin-top: 8px;
  }
  .sv-mood-cue-card__duration {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 12px;
    font-style: italic;
    color: rgba(253, 250, 244, 0.6);
    margin-top: 6px;
  }
  .sv-mood-cue-card__steps {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 13px;
    color: rgba(253, 250, 244, 0.75);
    line-height: 1.7;
    margin-top: 16px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .sv-mood-cue-card__pairs-label {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #FFD786;
    margin-top: 16px;
  }
  .sv-mood-cue-card__pairs-product {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 13px;
    color: #FDFAF4;
    margin-top: 4px;
  }
  .sv-mood-cue-card__link {
    display: inline-block;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 13px;
    color: rgba(253, 250, 244, 0.8);
    margin-top: 20px;
  }
  .sv-mood-cue-card__link:hover { text-decoration: underline; }

  /* ── Section 6: Spotify ─────────────────────────────────── */
  .sv-mood-spotify {
    padding: 40px 24px;
  }
  .sv-mood-spotify__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .sv-mood-spotify__left {}
  .sv-mood-spotify__eyebrow {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(0, 40, 22, 0.7);
    margin-bottom: 10px;
  }
  .sv-mood-spotify__copy {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 28px;
    color: #002816;
    line-height: 1.25;
  }
  .sv-mood-spotify__right {
    display: flex;
    align-items: center;
  }
  .sv-mood-spotify__embed {
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
  }
  .sv-mood-spotify__placeholder {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 13px;
    color: rgba(0, 40, 22, 0.5);
    font-style: italic;
  }

  /* ── Section 7: Key Ingredients ────────────────────────── */
  .sv-mood-ingredients {
    background: #FDFAF4;
    padding: 80px 24px;
  }
  .sv-mood-ingredients__inner {
    max-width: 1200px;
    margin: 0 auto;
  }
  .sv-mood-ingredients__header {
    text-align: center;
    margin-bottom: 48px;
  }
  .sv-mood-ingredients__eyebrow {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 12px;
  }
  .sv-mood-ingredients__headline {
    font-family: 'Cormorant Garamond', serif;
    font-size: 28px;
    color: #002816;
    line-height: 1.2;
  }
  .sv-mood-ingredients__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .sv-mood-ing-card {
    border: 1px solid rgba(74, 123, 94, 0.2);
    border-radius: 12px;
    padding: 28px 24px;
  }
  .sv-mood-ing-card__img-wrap {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid var(--mood-color, #002816);
    flex-shrink: 0;
  }
  .sv-mood-ing-card__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .sv-mood-ing-card__fallback {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--mood-color, #002816);
    border: 2px solid var(--mood-color, #002816);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px;
    color: #FDFAF4;
    flex-shrink: 0;
  }
  .sv-mood-ing-card__name {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #002816;
    margin-top: 16px;
  }
  .sv-mood-ing-card__mechanism {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 13px;
    color: #4A7B5E;
    line-height: 1.6;
    margin-top: 8px;
  }
  .sv-mood-ing-card__found-label {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #b6522d;
    margin-top: 12px;
  }
  .sv-mood-ing-card__found-in {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 13px;
    color: #002816;
    margin-top: 4px;
  }

  /* ── Desktop Breakpoint ─────────────────────────────────── */
  @media (min-width: 768px) {
    /* Hero */
    .sv-mood-hero { height: 90vh; }
    .sv-mood-hero__name { font-size: 96px; }
    .sv-mood-hero__descriptor { font-size: 22px; }

    /* Spacer */
    .sv-mood-spacer { padding: 96px 40px; }
    .sv-mood-spacer__statement { font-size: 52px; }

    /* Intro */
    .sv-mood-intro { padding: 80px 80px; }
    .sv-mood-intro__inner {
      flex-direction: row;
      align-items: center;
      gap: 60px;
    }
    .sv-mood-intro__text { flex: 55; }
    .sv-mood-intro__image-wrap { flex: 45; }
    .sv-mood-intro__headline { font-size: 42px; }

    /* Hero Product */
    .sv-mood-hero-product__inner { flex-direction: row; }
    .sv-mood-hero-product__image-wrap {
      flex: 1;
      aspect-ratio: 1 / 1;
    }
    .sv-mood-hero-product__content {
      flex: 1;
      padding: 64px;
    }

    /* Also In Mood */
    .sv-mood-also { padding: 0 80px 80px; }
    .sv-mood-also__grid { grid-template-columns: repeat(3, 1fr); }

    /* Mood Cues */
    .sv-mood-cues { padding: 80px 80px; }
    .sv-mood-cues__headline { font-size: 42px; }
    .sv-mood-cues__grid { grid-template-columns: repeat(3, 1fr); }

    /* Spotify */
    .sv-mood-spotify__inner {
      flex-direction: row;
      align-items: center;
      gap: 60px;
    }
    .sv-mood-spotify__left { flex: 1; }
    .sv-mood-spotify__right { flex: 1; }

    /* Ingredients */
    .sv-mood-ingredients { padding: 80px 80px; }
    .sv-mood-ingredients__headline { font-size: 38px; }
    .sv-mood-ingredients__grid { grid-template-columns: repeat(4, 1fr); }
  }
</style>

{% assign mood_color = section.settings.hero_color | default: '#002816' %}

<div class="sv-mood" style="--mood-color: {{ mood_color }};">

  {%- comment -%}── SECTION 1: HERO BANNER ─────────────────────────────────{%- endcomment -%}
  <div class="sv-mood-hero">
    {% if section.settings.hero_image != blank %}
      <img
        class="sv-mood-hero__img"
        src="{{ section.settings.hero_image | image_url: width: 2400 }}"
        alt="{{ section.settings.hero_name | escape }}"
        loading="eager"
        width="2400"
        height="1350"
      >
    {% else %}
      <div class="sv-mood-hero__img" style="background: {{ mood_color }};"></div>
    {% endif %}
    <div class="sv-mood-hero__overlay" style="background-color: {{ mood_color }}; opacity: 0.4;"></div>
    <div class="sv-mood-hero__content">
      {% if section.settings.hero_number != blank %}
        <p class="sv-mood-hero__number">{{ section.settings.hero_number }}</p>
      {% endif %}
      {% if section.settings.hero_name != blank %}
        <h1 class="sv-mood-hero__name">{{ section.settings.hero_name }}</h1>
      {% endif %}
      {% if section.settings.hero_descriptor != blank %}
        <p class="sv-mood-hero__descriptor">{{ section.settings.hero_descriptor }}</p>
      {% endif %}
    </div>
  </div>

  {%- comment -%}── SECTION 2: EDITORIAL SPACER ────────────────────────────{%- endcomment -%}
  {% if section.settings.spacer_statement != blank %}
    <div class="sv-mood-spacer">
      <div class="sv-mood-spacer__inner">
        <p class="sv-mood-spacer__statement">{{ section.settings.spacer_statement }}</p>
      </div>
    </div>
  {% endif %}

  {%- comment -%}── SECTION 3: MOOD INTRODUCTION ───────────────────────────{%- endcomment -%}
  <div class="sv-mood-intro">
    <div class="sv-mood-intro__inner">
      <div class="sv-mood-intro__text">
        {% if section.settings.intro_eyebrow != blank %}
          <p class="sv-mood-intro__eyebrow" style="color: {{ mood_color }};">{{ section.settings.intro_eyebrow }}</p>
        {% endif %}
        {% if section.settings.intro_headline != blank %}
          <h2 class="sv-mood-intro__headline">{{ section.settings.intro_headline }}</h2>
        {% endif %}
        {% if section.settings.intro_body != blank %}
          <p class="sv-mood-intro__body">{{ section.settings.intro_body }}</p>
        {% endif %}
      </div>
      {% if section.settings.intro_image != blank %}
        <div class="sv-mood-intro__image-wrap">
          <img
            src="{{ section.settings.intro_image | image_url: width: 900 }}"
            alt="{{ section.settings.intro_headline | escape }}"
            loading="lazy"
            width="900"
            height="1200"
          >
        </div>
      {% endif %}
    </div>
  </div>

  {%- comment -%}── SECTION 4A: HERO PRODUCT ───────────────────────────────{%- endcomment -%}
  <div class="sv-mood-hero-product">
    <div class="sv-mood-hero-product__inner">
      <div class="sv-mood-hero-product__image-wrap">
        {% if section.settings.hero_product_image != blank %}
          <img
            src="{{ section.settings.hero_product_image | image_url: width: 1200 }}"
            alt="{{ section.settings.hero_product_name | escape }}"
            loading="lazy"
            width="1200"
            height="1200"
          >
        {% else %}
          <img
            src="https://images.pexels.com/photos/3785147/pexels-photo-3785147.jpeg?auto=compress&cs=tinysrgb&w=800"
            alt="Product image"
            loading="lazy"
            width="800"
            height="800"
          >
        {% endif %}
      </div>

      <div class="sv-mood-hero-product__content">
        <p class="sv-mood-product__eyebrow" style="color: {{ mood_color }};">Primary Product</p>

        {% if section.settings.hero_product_name != blank %}
