                      alt="{{ display_name | escape }}"
                      loading="lazy"
                      width="56"
                      height="56"
                    >
                  </div>
                {% else %}
                  <div class="sv-mood-ing-card__fallback">
                    {{ display_name | slice: 0, 1 | upcase }}
                  </div>
                {% endif %}
                <p class="sv-mood-ing-card__name">{{ display_name }}</p>
                {% assign display_mech = ing_mech_val | default: def_mech %}
                {% if display_mech != blank %}
                  <p class="sv-mood-ing-card__mechanism">{{ display_mech }}</p>
                {% endif %}
                {% if ing_found_val != blank %}
                  <p class="sv-mood-ing-card__found-label">Found In</p>
                  <p class="sv-mood-ing-card__found-in">{{ ing_found_val }}</p>
                {% endif %}
              </div>
            {% endif %}
          {% endif %}
        {% endfor %}

      </div>
    </div>
  </div>

</div>

<script>
(function() {
  var sectionId = {{ section.id | json }};
  var moodColor = {{ section.settings.hero_color | default: '#002816' | json }};

  // ── Size pill toggle + ATC ─────────────────────────────────────
  var pills = document.querySelectorAll('.sv-mood-size-pill');
  var priceDisplay = document.getElementById('sv-price-display-' + sectionId);
  var atcBtn = document.getElementById('sv-atc-btn-' + sectionId);
  var activeVariantId = null;
  var activePrice = null;

  // init from the default active pill
  pills.forEach(function(pill) {
    if (pill.classList.contains('active')) {
      activeVariantId = pill.dataset.variant;
      activePrice = pill.dataset.price;
      if (atcBtn) {
        atcBtn.textContent = 'ADD TO BAG — ' + activePrice;
      }
    }
  });

  pills.forEach(function(pill) {
    pill.addEventListener('click', function() {
      pills.forEach(function(p) {
        p.classList.remove('active');
        p.setAttribute('aria-pressed', 'false');
      });
      pill.classList.add('active');
      pill.setAttribute('aria-pressed', 'true');
      activeVariantId = pill.dataset.variant;
      activePrice = pill.dataset.price;
      if (priceDisplay) priceDisplay.textContent = activePrice;
      if (atcBtn) atcBtn.textContent = 'ADD TO BAG — ' + activePrice;
    });
  });

  if (atcBtn) {
    atcBtn.addEventListener('click', function() {
      if (!activeVariantId) {
        console.warn('Sage & Veda: No variant ID configured for this size.');
        return;
      }
      var btn = atcBtn;
      btn.textContent = 'ADDING...';
      btn.disabled = true;

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ id: activeVariantId, quantity: 1 })
      })
      .then(function(res) { return res.json(); })
      .then(function(data) {
        btn.textContent = 'ADDED ✓';
        setTimeout(function() {
          btn.textContent = 'ADD TO BAG — ' + activePrice;
          btn.disabled = false;
        }, 2000);
      })
      .catch(function(err) {
        console.error('Sage & Veda ATC error:', err);
        btn.textContent = 'TRY AGAIN';
        btn.disabled = false;
        setTimeout(function() {
          btn.textContent = 'ADD TO BAG — ' + activePrice;
        }, 2000);
      });
    });
  }

  // ── Spotify embed ──────────────────────────────────────────────
  var spotifyWrap = document.getElementById('sv-spotify-embed-' + sectionId);
  if (spotifyWrap) {
    var rawUrl = spotifyWrap.dataset.url;
    if (rawUrl && rawUrl.trim() !== '') {
      var embedUrl = rawUrl.replace('open.spotify.com/', 'open.spotify.com/embed/');
      var iframe = document.createElement('iframe');
      iframe.src = embedUrl;
      iframe.width = '100%';
      iframe.height = '80';
      iframe.frameBorder = '0';
      iframe.allow = 'autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture';
      iframe.loading = 'lazy';
      iframe.style.borderRadius = '12px';
      spotifyWrap.appendChild(iframe);
    }
  }
})();
</script>

