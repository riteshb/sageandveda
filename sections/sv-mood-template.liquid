        {% for n in ing_nums %}
          {% assign ing_name_key = 'ing' | append: n | append: '_name' %}
          {% assign ing_mech_key = 'ing' | append: n | append: '_mechanism' %}
          {% assign ing_image_key = 'ing' | append: n | append: '_image' %}
          {% assign ing_found_key = 'ing' | append: n | append: '_found_in' %}
          {% assign ing_name_val = section.settings[ing_name_key] %}
          {% assign ing_mech_val = section.settings[ing_mech_key] %}
          {% assign ing_image_val = section.settings[ing_image_key] %}
          {% assign ing_found_val = section.settings[ing_found_key] %}
          {% assign idx = forloop.index0 %}
          {% assign def_name = ing_defaults_name[idx] %}
          {% assign def_mech = ing_defaults_mech[idx] %}

          {% if ing_name_val != blank or forloop.index <= 2 %}
            {% assign display_name = ing_name_val | default: def_name %}
