{% comment %} sv-mood-main.liquid — Sage & Veda Mood Main Page {% endcomment %}

<style>
  /* ── Reset & shared ── */
  .sv-mood * { box-sizing: border-box; margin: 0; padding: 0; }

  /* ── SECTION 1: HERO ── */
  .sv-mood-hero {
    position: relative;
    width: 100%;
    height: 70vh;
    overflow: hidden;
  }
  .sv-mood-hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .sv-mood-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.35);
  }
  .sv-mood-hero__text {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 0 24px;
    gap: 16px;
  }
  .sv-mood-hero__eyebrow {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #FFD786;
  }
  .sv-mood-hero__headline {
    font-family: 'Cormorant Garamond', serif;
    font-size: 40px;
    font-weight: 400;
    line-height: 1.15;
    color: #FDFAF4;
  }

  @media (min-width: 768px) {
    .sv-mood-hero { height: 90vh; }
    .sv-mood-hero__headline { font-size: 64px; }
  }

  /* ── SECTION 2: EDITORIAL SPACER ── */
  .sv-mood-spacer {
    background: #FDFAF4;
    padding: 56px 24px;
    text-align: center;
  }
  .sv-mood-spacer__inner {
    max-width: 640px;
    margin: 0 auto;
  }
  .sv-mood-spacer__eyebrow {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #b6522d;
    margin-bottom: 20px;
  }
  .sv-mood-spacer__statement {
    font-family: 'Cormorant Garamond', serif;
    font-size: 30px;
    font-weight: 400;
    line-height: 1.3;
    color: #002816;
  }

  @media (min-width: 768px) {
    .sv-mood-spacer { padding: 80px 48px; }
    .sv-mood-spacer__statement { font-size: 42px; }
  }

  /* ── SECTION 3: MOOD CARDS ── */
  .sv-mood-cards {
    background: #FDFAF4;
    padding: 0 24px 80px;
  }
  .sv-mood-cards__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    max-width: 1280px;
    margin: 0 auto;
  }
  .sv-mood-card {
    text-decoration: none;
    display: block;
    border-radius: 12px;
    overflow: hidden;
    position: relative;
  }
  .sv-mood-card__img-wrap {
    position: relative;
    width: 100%;
    padding-top: 125%; /* 4/5 ratio */
    overflow: hidden;
    border-radius: 12px;
  }
  .sv-mood-card__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 12px;
    transition: transform 0.5s ease;
  }
  .sv-mood-card:hover .sv-mood-card__img {
    transform: scale(1.04);
  }
  .sv-mood-card__dark-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0);
    border-radius: 12px;
    transition: background 0.3s ease;
    pointer-events: none;
  }
  .sv-mood-card:hover .sv-mood-card__dark-overlay {
    background: rgba(0,0,0,0.35);
  }
  .sv-mood-card__pill {
    position: absolute;
    bottom: 16px;
    left: 16px;
    color: #002816;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 999px;
    z-index: 2;
    transition: opacity 0.3s ease;
  }
  .sv-mood-card:hover .sv-mood-card__pill {
    opacity: 0;
  }
  .sv-mood-card__plus {
    position: absolute;
    bottom: 16px;
    right: 16px;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(253,250,244,0.9);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 18px;
    color: #002816;
    z-index: 2;
    transition: opacity 0.3s ease;
  }
  .sv-mood-card:hover .sv-mood-card__plus {
    opacity: 0;
  }
  .sv-mood-card__hover-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 24px;
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 3;
    pointer-events: none;
  }
  .sv-mood-card:hover .sv-mood-card__hover-content {
    opacity: 1;
    pointer-events: auto;
  }
  .sv-mood-card__hover-name {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #FDFAF4;
    margin-bottom: 10px;
  }
  .sv-mood-card__hover-desc {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 18px;
    color: #FDFAF4;
    margin-bottom: 14px;
  }
  .sv-mood-card__hover-link {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #FDFAF4;
    text-decoration: underline;
    pointer-events: auto;
  }

  @media (min-width: 768px) {
    .sv-mood-cards { padding: 0 48px 80px; }
    .sv-mood-cards__grid { grid-template-columns: repeat(3, 1fr); }
  }

  /* ── SECTION 4: MOOD CUES ── */
  .sv-mood-cues {
    background: #002816;
    padding: 56px 24px;
  }
  .sv-mood-cues__header {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 48px;
  }
  .sv-mood-cues__eyebrow {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #FFD786;
    margin-bottom: 16px;
  }
  .sv-mood-cues__headline {
    font-family: 'Cormorant Garamond', serif;
    font-size: 30px;
    color: #FDFAF4;
    line-height: 1.2;
    margin-bottom: 16px;
  }
  .sv-mood-cues__subtext {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 15px;
    color: rgba(253,250,244,0.7);
    line-height: 1.7;
    max-width: 520px;
    margin: 0 auto;
  }
  .sv-mood-cues__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    max-width: 1280px;
    margin: 0 auto;
  }
  .sv-mood-cue-card {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 12px;
    padding: 32px;
  }
  .sv-mood-cue-card__tag {
    display: inline-block;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 5px 12px;
    border-radius: 999px;
  }
  .sv-mood-cue-card__tag--calm {
    background: #A8C5A0;
    color: #002816;
  }
  .sv-mood-cue-card__tag--confident {
    background: #b6522d;
    color: #FDFAF4;
  }
  .sv-mood-cue-card__tag--lifted {
    background: #FFD786;
    color: #002816;
  }
  .sv-mood-cue-card__name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 26px;
    color: #FDFAF4;
    margin-top: 16px;
    line-height: 1.2;
  }
  .sv-mood-cue-card__duration {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 12px;
    font-style: italic;
    color: rgba(253,250,244,0.6);
    margin-top: 6px;
  }
  .sv-mood-cue-card__desc {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 14px;
    color: rgba(253,250,244,0.75);
    line-height: 1.7;
    margin-top: 14px;
  }
  .sv-mood-cue-card__pairs {
    margin-top: 16px;
  }
  .sv-mood-cue-card__pairs-label {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #FFD786;
    display: block;
    margin-bottom: 4px;
  }
  .sv-mood-cue-card__pairs-product {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 13px;
    color: #FDFAF4;
  }
  .sv-mood-cue-card__link {
    display: inline-block;
    margin-top: 20px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 13px;
    color: rgba(253,250,244,0.8);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s ease;
  }
  .sv-mood-cue-card__link:hover {
    border-color: rgba(253,250,244,0.8);
  }

  @media (min-width: 768px) {
    .sv-mood-cues { padding: 80px 48px; }
    .sv-mood-cues__headline { font-size: 42px; }
    .sv-mood-cues__grid { grid-template-columns: repeat(3, 1fr); }
  }

  /* ── SECTION 5: THE SCIENCE ── */
  .sv-mood-science {
    background: #FDFAF4;
    padding: 56px 24px;
  }
  .sv-mood-science__header {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 56px;
  }
  .sv-mood-science__eyebrow {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #b6522d;
    margin-bottom: 16px;
  }
  .sv-mood-science__headline {
    font-family: 'Cormorant Garamond', serif;
    font-size: 30px;
    color: #002816;
    line-height: 1.2;
  }
  .sv-mood-science__block {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    max-width: 1280px;
    margin: 0 auto 48px;
    align-items: center;
  }
  .sv-mood-science__block:last-child {
    margin-bottom: 0;
  }
  .sv-mood-science__img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    border-radius: 8px;
    display: block;
  }
  .sv-mood-science__text-eyebrow {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #b6522d;
    margin-bottom: 14px;
  }
  .sv-mood-science__text-headline {
    font-family: 'Cormorant Garamond', serif;
    font-size: 32px;
    color: #002816;
    line-height: 1.2;
    margin-bottom: 16px;
  }
  .sv-mood-science__text-body {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 16px;
    color: #4A7B5E;
    line-height: 1.8;
  }

  @media (min-width: 768px) {
    .sv-mood-science { padding: 80px 48px; }
    .sv-mood-science__headline { font-size: 42px; }
    .sv-mood-science__block {
      grid-template-columns: 1fr 1fr;
      gap: 64px;
    }
    .sv-mood-science__block--reverse .sv-mood-science__img-col {
      order: 2;
    }
    .sv-mood-science__block--reverse .sv-mood-science__text-col {
      order: 1;
    }
  }

  /* ── SECTION 6: WHAT TO EXPECT ── */
  .sv-mood-expect {
    background: #FDFAF4;
    padding: 56px 24px;
  }
  .sv-mood-expect__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    max-width: 1280px;
    margin: 0 auto;
    align-items: stretch;
  }
  .sv-mood-expect__eyebrow {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #b6522d;
    margin-bottom: 14px;
  }
  .sv-mood-expect__headline {
    font-family: 'Cormorant Garamond', serif;
    font-size: 38px;
    color: #002816;
    line-height: 1.2;
    margin-bottom: 32px;
  }
  .sv-mood-expect__block-label {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 14px;
    font-weight: 700;
    color: #002816;
    margin-bottom: 10px;
  }
  .sv-mood-expect__block-body {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 15px;
    color: #4A7B5E;
    line-height: 1.8;
  }
  .sv-mood-expect__divider {
    border: none;
    border-top: 1px solid rgba(74,123,94,0.2);
    margin: 24px 0;
  }
  .sv-mood-expect__img {
    width: 100%;
    height: 400px;
    object-fit: cover;
    border-radius: 8px;
    display: block;
  }

  @media (min-width: 768px) {
    .sv-mood-expect { padding: 80px 48px; }
    .sv-mood-expect__grid { grid-template-columns: 1fr 1fr; }
    .sv-mood-expect__img { height: 100%; min-height: 500px; }
  }

  /* ── SECTION 7: SHOP CTA BANNER ── */
  .sv-mood-cta {
    background: #002816;
    padding: 56px 24px;
    text-align: center;
  }
  .sv-mood-cta__eyebrow {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #FFD786;
    margin-bottom: 20px;
  }
  .sv-mood-cta__headline {
    font-family: 'Cormorant Garamond', serif;
    font-size: 34px;
    color: #FDFAF4;
    line-height: 1.15;
    margin-bottom: 16px;
  }
  .sv-mood-cta__subline {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 15px;
    color: rgba(253,250,244,0.7);
    line-height: 1.7;
    max-width: 480px;
    margin: 0 auto 36px;
  }
  .sv-mood-cta__btn {
    display: inline-block;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #FDFAF4;
    background: transparent;
    border: 1.5px solid #FDFAF4;
    padding: 14px 36px;
    border-radius: 999px;
    text-decoration: none;
    transition: background 0.25s ease, color 0.25s ease;
  }
  .sv-mood-cta__btn:hover {
    background: #FDFAF4;
    color: #002816;
  }

  @media (min-width: 768px) {
    .sv-mood-cta { padding: 80px 48px; }
    .sv-mood-cta__headline { font-size: 48px; }
  }

  /* ── SECTION 8: FAQ ── */
  .sv-mood-faq {
    background: #FDFAF4;
    padding: 56px 24px;
  }
  .sv-mood-faq__inner {
    max-width: 720px;
    margin: 0 auto;
  }
  .sv-mood-faq__header {
    text-align: center;
    margin-bottom: 56px;
  }
  .sv-mood-faq__eyebrow {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #b6522d;
    margin-bottom: 16px;
  }
  .sv-mood-faq__headline {
    font-family: 'Cormorant Garamond', serif;
    font-size: 38px;
    color: #002816;
    line-height: 1.2;
  }
  .sv-mood-faq__item {
    border-top: 1px solid rgba(0,40,22,0.15);
  }
  .sv-mood-faq__item:last-child {
    border-bottom: 1px solid rgba(0,40,22,0.15);
  }
  .sv-mood-faq__trigger {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: 20px 0;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    gap: 16px;
  }
  .sv-mood-faq__question {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 15px;
    font-weight: 600;
    color: #002816;
    line-height: 1.5;
  }
  .sv-mood-faq__icon {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 18px;
    color: #002816;
    flex-shrink: 0;
    line-height: 1;
    transition: transform 0.2s ease;
    user-select: none;
  }
  .sv-mood-faq__answer-wrap {
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.35s ease;
  }
  .sv-mood-faq__answer-wrap.is-open {
    max-height: 600px;
  }
  .sv-mood-faq__answer {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 15px;
    color: #4A7B5E;
    line-height: 1.8;
    padding-bottom: 20px;
  }

  @media (min-width: 768px) {
    .sv-mood-faq { padding: 80px 48px; }
  }
</style>

<div class="sv-mood">

  {%- comment -%} ── SECTION 1: HERO ── {%- endcomment -%}
  <section class="sv-mood-hero">
    {%- if section.settings.hero_image != blank -%}
      <img
        class="sv-mood-hero__img"
        src="{{ section.settings.hero_image | image_url: width: 1600 }}"
        alt="{{ section.settings.hero_image.alt | escape }}"
        loading="eager"
        width="1600"
      >
    {%- else -%}
      <img
        class="sv-mood-hero__img"
        src="https://images.pexels.com/photos/3765150/pexels-photo-3765150.jpeg?auto=compress&cs=tinysrgb&w=1600"
        alt="Mood hero"
        loading="eager"
        width="1600"
      >
    {%- endif -%}
    <div class="sv-mood-hero__overlay"></div>
    <div class="sv-mood-hero__text">
      <p class="sv-mood-hero__eyebrow">{{ section.settings.hero_eyebrow }}</p>
      <h1 class="sv-mood-hero__headline">{{ section.settings.hero_headline }}</h1>
    </div>
  </section>

  {%- comment -%} ── SECTION 2: EDITORIAL SPACER ── {%- endcomment -%}
  <section class="sv-mood-spacer">
    <div class="sv-mood-spacer__inner">
      <p class="sv-mood-spacer__eyebrow">{{ section.settings.spacer_eyebrow }}</p>
      <p class="sv-mood-spacer__statement">{{ section.settings.spacer_statement }}</p>
    </div>
  </section>

  {%- comment -%} ── SECTION 3: THREE MOOD CARDS ── {%- endcomment -%}
  <section class="sv-mood-cards">
    <div class="sv-mood-cards__grid">

      {%- assign mood_keys = "1,2,3" | split: "," -%}
      {%- assign mood_defaults_name = "Calm,Confident,Lifted" | split: "," -%}
      {%- assign mood_defaults_desc = "Radiant skin. Quiet mind.,Rooted. Strong. Present.,An instant shift. Luminous." | split: "," -%}
      {%- assign mood_defaults_link = "/pages/mood-calm,/pages/mood-confident,/pages/mood-lifted" | split: "," -%}
      {%- assign mood_defaults_color = "#A8C5A0,#b6522d,#FFD786" | split: "," -%}
      {%- assign mood_pexels = "https://images.pexels.com/photos/6153350/pexels-photo-6153350.jpeg?auto=compress&cs=tinysrgb&w=800,https://images.pexels.com/photos/3373716/pexels-photo-3373716.jpeg?auto=compress&cs=tinysrgb&w=800,https://images.pexels.com/photos/5240678/pexels-photo-5240678.jpeg?auto=compress&cs=tinysrgb&w=800" | split: "," -%}

      {%- for i in (1..3) -%}
        {%- assign idx = forloop.index0 -%}
        {%- assign img_key = "mood" | append: i | append: "_image" -%}
        {%- assign name_key = "mood" | append: i | append: "_name" -%}
        {%- assign desc_key = "mood" | append: i | append: "_descriptor" -%}
        {%- assign link_key = "mood" | append: i | append: "_link" -%}
        {%- assign color_key = "mood" | append: i | append: "_color" -%}
        {%- assign card_name = section.settings[name_key] | default: mood_defaults_name[idx] -%}
        {%- assign card_desc = section.settings[desc_key] | default: mood_defaults_desc[idx] -%}
        {%- assign card_link = section.settings[link_key] | default: mood_defaults_link[idx] -%}
        {%- assign card_color = section.settings[color_key] | default: mood_defaults_color[idx] -%}

        <a class="sv-mood-card" href="{{ card_link }}">
          <div class="sv-mood-card__img-wrap">
            {%- if section.settings[img_key] != blank -%}
              <img
                class="sv-mood-card__img"
                src="{{ section.settings[img_key] | image_url: width: 800 }}"
                alt="{{ card_name }}"
                loading="lazy"
                width="800"
              >
            {%- else -%}
              <img
                class="sv-mood-card__img"
                src="{{ mood_pexels[idx] }}"
                alt="{{ card_name }}"
                loading="lazy"
                width="800"
              >
            {%- endif -%}
            <div class="sv-mood-card__dark-overlay"></div>
            <span class="sv-mood-card__pill" style="background-color: {{ card_color }};">{{ card_name }}</span>
            <span class="sv-mood-card__plus" aria-hidden="true">+</span>
            <div class="sv-mood-card__hover-content">
              <span class="sv-mood-card__hover-name">{{ card_name }}</span>
              <span class="sv-mood-card__hover-desc">{{ card_desc }}</span>
