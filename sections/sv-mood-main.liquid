  {%- comment -%} ── SECTION 4: MOOD CUES ── {%- endcomment -%}
  <section class="sv-mood-cues">
    <div class="sv-mood-cues__header">
      <p class="sv-mood-cues__eyebrow">MOOD CUES</p>
      <h2 class="sv-mood-cues__headline">{{ section.settings.cues_headline }}</h2>
      <p class="sv-mood-cues__subtext">{{ section.settings.cues_subtext }}</p>
    </div>
    <div class="sv-mood-cues__grid">

      {%- assign cue_default_moods = "Calm,Confident,Lifted" | split: "," -%}
      {%- assign cue_default_durations = "< 2 min · Touch,< 3 min · Breath,< 2 min · Movement" | split: "," -%}

      {%- for i in (1..3) -%}
        {%- assign idx = forloop.index0 -%}
        {%- assign cue_name_key = "cue" | append: i | append: "_name" -%}
        {%- assign cue_dur_key = "cue" | append: i | append: "_duration" -%}
        {%- assign cue_desc_key = "cue" | append: i | append: "_desc" -%}
        {%- assign cue_product_key = "cue" | append: i | append: "_product" -%}
        {%- assign cue_link_key = "cue" | append: i | append: "_link" -%}
        {%- assign cue_mood_key = "cue" | append: i | append: "_mood" -%}
        {%- assign cue_mood_val = section.settings[cue_mood_key] | default: cue_default_moods[idx] | downcase -%}

        <div class="sv-mood-cue-card">
          <span class="sv-mood-cue-card__tag sv-mood-cue-card__tag--{{ cue_mood_val }}">
            {{ section.settings[cue_mood_key] | default: cue_default_moods[idx] }}
          </span>
          <h3 class="sv-mood-cue-card__name">{{ section.settings[cue_name_key] | default: "Mood Cue " | append: i }}</h3>
          <p class="sv-mood-cue-card__duration">{{ section.settings[cue_dur_key] | default: cue_default_durations[idx] }}</p>
          {%- if section.settings[cue_desc_key] != blank -%}
            <p class="sv-mood-cue-card__desc">{{ section.settings[cue_desc_key] }}</p>
          {%- endif -%}
          {%- if section.settings[cue_product_key] != blank -%}
            <div class="sv-mood-cue-card__pairs">
              <span class="sv-mood-cue-card__pairs-label">Pairs with</span>
              <span class="sv-mood-cue-card__pairs-product">{{ section.settings[cue_product_key] }}</span>
            </div>
          {%- endif -%}
          {%- if section.settings[cue_link_key] != blank -%}
            <a class="sv-mood-cue-card__link" href="{{ section.settings[cue_link_key] }}">Read the full Mood Cue &rarr;</a>
          {%- endif -%}
        </div>
      {%- endfor -%}

    </div>
  </section>

  {%- comment -%} ── SECTION 5: THE SCIENCE ── {%- endcomment -%}
  <section class="sv-mood-science">
    <div class="sv-mood-science__header">
      <p class="sv-mood-science__eyebrow">THE SCIENCE</p>
      <h2 class="sv-mood-science__headline">{{ section.settings.science_headline }}</h2>
    </div>

    {%- assign sci_default_eyebrows = "THE SKIN-BRAIN LOOP,SCENT + THE LIMBIC SYSTEM,ADAPTOGENS, APPLIED TOPICALLY" | split: "," -%}
    {%- assign sci_pexels = "https://images.pexels.com/photos/3735657/pexels-photo-3735657.jpeg?auto=compress&cs=tinysrgb&w=800,https://images.pexels.com/photos/6621461/pexels-photo-6621461.jpeg?auto=compress&cs=tinysrgb&w=800,https://images.pexels.com/photos/4465124/pexels-photo-4465124.jpeg?auto=compress&cs=tinysrgb&w=800" | split: "," -%}

    {%- for i in (1..3) -%}
      {%- assign idx = forloop.index0 -%}
      {%- assign sci_img_key = "sci" | append: i | append: "_image" -%}
      {%- assign sci_eye_key = "sci" | append: i | append: "_eyebrow" -%}
      {%- assign sci_hl_key = "sci" | append: i | append: "_headline" -%}
      {%- assign sci_body_key = "sci" | append: i | append: "_body" -%}
      {%- assign sci_reverse = "" -%}
      {%- if i == 2 -%}{%- assign sci_reverse = " sv-mood-science__block--reverse" -%}{%- endif -%}

      <div class="sv-mood-science__block{{ sci_reverse }}">
        <div class="sv-mood-science__img-col">
          {%- if section.settings[sci_img_key] != blank -%}
            <img
              class="sv-mood-science__img"
              src="{{ section.settings[sci_img_key] | image_url: width: 800 }}"
              alt="{{ section.settings[sci_eye_key] | default: sci_default_eyebrows[idx] }}"
              loading="lazy"
              width="800"
            >
          {%- else -%}
            <img
              class="sv-mood-science__img"
              src="{{ sci_pexels[idx] }}"
              alt="{{ sci_default_eyebrows[idx] }}"
              loading="lazy"
              width="800"
            >
          {%- endif -%}
        </div>
        <div class="sv-mood-science__text-col">
          <p class="sv-mood-science__text-eyebrow">{{ section.settings[sci_eye_key] | default: sci_default_eyebrows[idx] }}</p>
          {%- if section.settings[sci_hl_key] != blank -%}
            <h3 class="sv-mood-science__text-headline">{{ section.settings[sci_hl_key] }}</h3>
          {%- endif -%}
          {%- if section.settings[sci_body_key] != blank -%}
            <div class="sv-mood-science__text-body">{{ section.settings[sci_body_key] | newline_to_br }}</div>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}

  </section>

  {%- comment -%} ── SECTION 6: WHAT TO EXPECT ── {%- endcomment -%}
