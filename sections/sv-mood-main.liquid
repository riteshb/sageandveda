    <a class="sv-mood-cta__btn" href="/collections/all">Shop the collection</a>
  </section>

  {%- comment -%} ── SECTION 8: FAQ ── {%- endcomment -%}
  <section class="sv-mood-faq">
    <div class="sv-mood-faq__inner">
      <div class="sv-mood-faq__header">
        <p class="sv-mood-faq__eyebrow">QUESTIONS</p>
        <h2 class="sv-mood-faq__headline">Everything you want to know.</h2>
      </div>

      {%- assign faq_default_qs = "How quickly will I notice a difference?|Can I use products from more than one mood?|Which mood is right for me?|Are these products suitable for all skin types?|How do Mood Cues work with the products?|What makes Sage & Veda different from other oils?" | split: "|" -%}

      {%- for i in (1..6) -%}
        {%- assign idx = forloop.index0 -%}
        {%- assign faq_q_key = "faq" | append: i | append: "_q" -%}
        {%- assign faq_a_key = "faq" | append: i | append: "_a" -%}
        {%- assign faq_q_val = section.settings[faq_q_key] | default: faq_default_qs[idx] -%}
        {%- assign is_first = "" -%}
        {%- if i == 1 -%}{%- assign is_first = " is-open" -%}{%- endif -%}

        <div class="sv-mood-faq__item" data-faq="{{ i }}">
          <button
            class="sv-mood-faq__trigger"
            aria-expanded="{%- if i == 1 -%}true{%- else -%}false{%- endif -%}"
            aria-controls="faq-answer-{{ section.id }}-{{ i }}"
          >
            <span class="sv-mood-faq__question">{{ faq_q_val }}</span>
            <span class="sv-mood-faq__icon" aria-hidden="true">{%- if i == 1 -%}&times;{%- else -%}+{%- endif -%}</span>
          </button>
          <div
            id="faq-answer-{{ section.id }}-{{ i }}"
            class="sv-mood-faq__answer-wrap{{ is_first }}"
          >
            {%- if section.settings[faq_a_key] != blank -%}
              <p class="sv-mood-faq__answer">{{ section.settings[faq_a_key] }}</p>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}

    </div>
  </section>

</div>

<script>
  (function () {
    var section = document.querySelector('.sv-mood-faq');
    if (!section) return;

    var items = section.querySelectorAll('.sv-mood-faq__item');

    items.forEach(function (item) {
      var trigger = item.querySelector('.sv-mood-faq__trigger');
      var answerWrap = item.querySelector('.sv-mood-faq__answer-wrap');
      var icon = item.querySelector('.sv-mood-faq__icon');

      trigger.addEventListener('click', function () {
        var isOpen = answerWrap.classList.contains('is-open');

        // Close all
        items.forEach(function (otherItem) {
          var otherWrap = otherItem.querySelector('.sv-mood-faq__answer-wrap');
          var otherIcon = otherItem.querySelector('.sv-mood-faq__icon');
          var otherTrigger = otherItem.querySelector('.sv-mood-faq__trigger');
          otherWrap.classList.remove('is-open');
          otherIcon.innerHTML = '+';
          otherTrigger.setAttribute('aria-expanded', 'false');
        });

        // Open clicked if it was closed
        if (!isOpen) {
          answerWrap.classList.add('is-open');
          icon.innerHTML = '&times;';
          trigger.setAttribute('aria-expanded', 'true');
        }
      });
    });
  })();
</script>

